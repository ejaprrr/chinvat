FROM node:20-alpine AS migrate

WORKDIR /db

# Prisma engines need OpenSSL libraries present in the container runtime.
RUN apk add --no-cache openssl libc6-compat

# Install deps
COPY prisma/package.json ./
RUN npm install --omit=dev

# Copy Prisma schema + migrations
COPY prisma/schema.prisma ./prisma/schema.prisma
COPY prisma/migrations ./prisma/migrations

# Generate Prisma client (needed for prisma CLI internals)
RUN npx prisma generate

# DATABASE_URL must be provided at runtime via environment variable
# e.g. postgresql://user:pass@host:5432/dbname

ENTRYPOINT ["npx", "prisma", "migrate", "deploy"]

