// Prisma schema – source of truth for the Chinvat database.
// Migrations are generated via `prisma migrate dev` locally and applied
// in CI/CD with `prisma migrate deploy`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  INDIVIDUAL
  LIBRARY

  @@map("user_type")
}

enum AccessLevel {
  SUPERADMIN
  ADMIN
  GOLD
  PREMIUM
  NORMAL

  @@map("access_level")
}

enum AuthSessionTokenKind {
  ACCESS
  REFRESH
}

model User {
  id              BigInt      @id @default(autoincrement())
  username        String      @unique @db.VarChar(100)
  fullName        String      @db.VarChar(255)
  phoneNumber     String?     @db.VarChar(40)
  email           String      @unique @db.VarChar(255)
  userType        UserType
  accessLevel     AccessLevel
  addressLine     String?     @db.VarChar(255)
  postalCode      String?     @db.VarChar(40)
  city            String?     @db.VarChar(120)
  country         String?     @db.VarChar(120)
  defaultLanguage String      @db.VarChar(12)
  createdAt       DateTime    @default(now()) @db.Timestamptz
  updatedAt       DateTime    @default(now()) @db.Timestamptz

  password      UserPassword?
  certificates  UserCertificate[]
  certificateCredentials CertificateCredential[]
  externalIdentities ExternalIdentity[]
  certificateEnrollments CertificateEnrollment[]
  resetTokens   AuthPasswordReset[]
  sessions      AuthSession[]
  auditEvents   AuthAuditEvent[]
  userRoles     UserRole[]

  @@map("user")
}

model UserPassword {
  userId              BigInt   @id
  passwordHash        String   @db.VarChar(255)
  passwordAlgorithm   String   @db.VarChar(50)
  passwordChangedAt   DateTime @default(now()) @db.Timestamptz
  recoveryRequired    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_password")
}

/// Digital certificate for certificate-based login (X.509 / client TLS)
model UserCertificate {
  id              BigInt    @id @default(autoincrement())
  userId          BigInt
  subjectDn       String    @db.VarChar(512)           // Certificate Subject DN
  issuerDn        String    @db.VarChar(512)           // Certificate Issuer DN
  serialNumber    String    @db.VarChar(128)           // Serial number (hex)
  thumbprintSha256 String   @unique @db.VarChar(64)    // SHA-256 fingerprint (hex)
  notBefore       DateTime  @db.Timestamptz
  notAfter        DateTime  @db.Timestamptz
  revokedAt       DateTime? @db.Timestamptz
  createdAt       DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_user_certificate_user_id")
  @@index([thumbprintSha256], name: "idx_user_certificate_thumbprint")
  @@map("user_certificate")
}

/// Enterprise-grade trust provider registry synchronized from LOTL/TSL or managed internally.
model TrustProvider {
  id                BigInt   @id @default(autoincrement())
  providerCode      String   @unique @db.VarChar(80)
  displayName       String   @db.VarChar(160)
  providerType      String   @db.VarChar(80)
  sourceType        String   @db.VarChar(80)
  countryCode       String?  @db.VarChar(2)
  lotlUrl           String?  @db.VarChar(1024)
  tslUrl            String?  @db.VarChar(1024)
  trustListKey      String?  @db.VarChar(255)
  active            Boolean  @default(true)
  lastSynchronizedAt DateTime? @db.Timestamptz
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @default(now()) @db.Timestamptz

  credentials       CertificateCredential[]
  externalIdentities ExternalIdentity[]

  @@index([providerType], name: "idx_trust_provider_provider_type")
  @@index([active], name: "idx_trust_provider_active")
  @@map("trust_provider")
}

/// Enterprise credential binding for X.509 login and signing use-cases.
model CertificateCredential {
  id                   BigInt   @id @default(autoincrement())
  userId               BigInt
  providerId           BigInt?
  providerCode         String?  @db.VarChar(80)
  credentialType       String   @db.VarChar(80)
  trustStatus          String   @db.VarChar(80)
  revocationStatus     String   @db.VarChar(80)
  assuranceLevel       String?  @db.VarChar(80)
  registrationSource   String   @db.VarChar(80)
  externalSubjectId    String?  @db.VarChar(255)
  linkedIdentitySource String?  @db.VarChar(120)
  certificatePem       String   @db.Text
  subjectDn            String   @db.VarChar(1024)
  issuerDn             String   @db.VarChar(1024)
  serialNumber         String   @db.VarChar(128)
  thumbprintSha256     String   @unique @db.VarChar(64)
  policyOids           String?  @db.Text
  qcStatementFlags     String?  @db.Text
  keyUsageFlags        String?  @db.Text
  extendedKeyUsageFlags String? @db.Text
  notBefore            DateTime @db.Timestamptz
  notAfter             DateTime @db.Timestamptz
  trustCheckedAt       DateTime? @db.Timestamptz
  revocationCheckedAt  DateTime? @db.Timestamptz
  approvedBy           String?  @db.VarChar(120)
  approvedAt           DateTime? @db.Timestamptz
  revokedBy            String?  @db.VarChar(120)
  revokedAt            DateTime? @db.Timestamptz
  isPrimary            Boolean  @default(false)
  lastSuccessfulAuthAt DateTime? @db.Timestamptz
  lastFailedAuthAt     DateTime? @db.Timestamptz
  failureCount         Int      @default(0)
  createdAt            DateTime @default(now()) @db.Timestamptz
  updatedAt            DateTime @default(now()) @db.Timestamptz

  user                 User @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             TrustProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  enrollments          CertificateEnrollment[]
  identityAuditEvents  IdentityAuditEvent[]

  @@index([userId], name: "idx_certificate_credential_user_id")
  @@index([providerId], name: "idx_certificate_credential_provider_id")
  @@index([providerCode], name: "idx_certificate_credential_provider_code")
  @@index([trustStatus], name: "idx_certificate_credential_trust_status")
  @@index([revocationStatus], name: "idx_certificate_credential_revocation_status")
  @@index([thumbprintSha256], name: "idx_certificate_credential_thumbprint")
  @@map("certificate_credential")
}

/// Enrollment and approval workflow for certificate onboarding.
model CertificateEnrollment {
  id                    BigInt   @id @default(autoincrement())
  userId                BigInt?
  certificateCredentialId BigInt?
  providerCode          String?  @db.VarChar(80)
  requestedBy           String   @db.VarChar(120)
  status                String   @db.VarChar(80)
  registrationSource    String   @db.VarChar(80)
  requestPayload        Json     @default("{}")
  reviewNotes           String?  @db.Text
  approvedBy            String?  @db.VarChar(120)
  approvedAt            DateTime? @db.Timestamptz
  rejectedBy            String?  @db.VarChar(120)
  rejectedAt            DateTime? @db.Timestamptz
  createdAt             DateTime @default(now()) @db.Timestamptz
  updatedAt             DateTime @default(now()) @db.Timestamptz

  user                  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  certificateCredential CertificateCredential? @relation(fields: [certificateCredentialId], references: [id], onDelete: SetNull)

  @@index([userId], name: "idx_certificate_enrollment_user_id")
  @@index([certificateCredentialId], name: "idx_certificate_enrollment_credential_id")
  @@index([status], name: "idx_certificate_enrollment_status")
  @@map("certificate_enrollment")
}

/// Linked external identity from eIDAS or another trust broker.
model ExternalIdentity {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt?
  providerId        BigInt?
  providerCode      String   @db.VarChar(80)
  identitySource    String   @db.VarChar(80)
  externalSubjectId String   @db.VarChar(255)
  assuranceLevel    String?  @db.VarChar(80)
  personIdentifier  String?  @db.VarChar(255)
  legalPersonIdentifier String? @db.VarChar(255)
  identityReference String? @db.VarChar(255)
  nationality       String? @db.VarChar(80)
  firstName         String?  @db.VarChar(160)
  familyName        String?  @db.VarChar(160)
  dateOfBirth       String?  @db.VarChar(40)
  rawClaimsJson     String?  @db.Text
  currentStatus     String   @db.VarChar(80)
  reviewedBy        String?  @db.VarChar(120)
  reviewedAt        DateTime? @db.Timestamptz
  reviewReason      String?  @db.Text
  linkedAt          DateTime? @db.Timestamptz
  unlinkedAt        DateTime? @db.Timestamptz
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @default(now()) @db.Timestamptz

  user              User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider          TrustProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  identityAuditEvents IdentityAuditEvent[]

  @@unique([providerCode, externalSubjectId], name: "uq_external_identity_provider_subject")
  @@index([userId], name: "idx_external_identity_user_id")
  @@index([providerId], name: "idx_external_identity_provider_id")
  @@map("external_identity")
}

/// Immutable high-level audit stream for trust and identity lifecycle events.
model IdentityAuditEvent {
  id                   BigInt   @id @default(autoincrement())
  eventType            String   @db.VarChar(120)
  actor                String?  @db.VarChar(120)
  userId               BigInt?
  certificateCredentialId BigInt?
  externalIdentityId   BigInt?
  details              Json     @default("{}")
  createdAt            DateTime @default(now()) @db.Timestamptz

  user                 User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  certificateCredential CertificateCredential? @relation(fields: [certificateCredentialId], references: [id], onDelete: SetNull)
  externalIdentity     ExternalIdentity? @relation(fields: [externalIdentityId], references: [id], onDelete: SetNull)

  @@index([eventType], name: "idx_identity_audit_event_event_type")
  @@index([userId], name: "idx_identity_audit_event_user_id")
  @@index([certificateCredentialId], name: "idx_identity_audit_event_credential_id")
  @@index([externalIdentityId], name: "idx_identity_audit_event_external_identity_id")
  @@map("identity_audit_event")
}

model AuthPasswordReset {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         BigInt
  resetTokenHash String    @db.VarChar(255)
  issuedAt       DateTime  @db.Timestamptz
  expiresAt      DateTime  @db.Timestamptz
  consumedAt     DateTime? @db.Timestamptz
  clientIp       String?   @db.VarChar(64)
  userAgent      String?   @db.VarChar(512)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_auth_password_reset_user_id")
  @@index([userId, resetTokenHash], name: "idx_auth_password_reset_user_hash")
  @@index([expiresAt], name: "idx_auth_password_reset_expires_at")
  @@map("auth_password_reset")
}

model AuthSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           BigInt
  sessionTokenHash String    @unique @db.VarChar(255)
  sessionTokenKind AuthSessionTokenKind
  issuedAt         DateTime  @default(now()) @db.Timestamptz
  expiresAt        DateTime  @db.Timestamptz
  revokedAt        DateTime? @db.Timestamptz
  clientIp         String?   @db.VarChar(64)
  userAgent        String?   @db.VarChar(512)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_auth_session_user_id")
  @@index([expiresAt], name: "idx_auth_session_expires_at")
  @@map("auth_session")
}

model AuthAuditEvent {
  id        BigInt   @id @default(autoincrement())
  eventType String   @db.VarChar(120)
  userId    BigInt?
  details   Json     @default("{}")
  createdAt DateTime @default(now()) @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType], name: "idx_auth_audit_event_event_type")
  @@map("auth_audit_event")
}

model RbacRole {
  id             BigInt @id @default(autoincrement())
  roleName       String @unique @db.VarChar(80)
  rolePermissions RbacRolePermission[]
  userRoles        UserRole[]

  @@map("rbac_role")
}

model RbacPermission {
  id             BigInt @id @default(autoincrement())
  permissionCode String @unique @db.VarChar(120)
  description    String? @db.VarChar(255)
  createdAt      DateTime @default(now()) @db.Timestamptz
  rolePermissions RbacRolePermission[]

  @@map("rbac_permission")
}

model RbacRolePermission {
  roleId       BigInt
  permissionId BigInt

  role       RbacRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission RbacPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], name: "idx_rbac_role_permission_permission_id")
  @@map("rbac_role_permission")
}

model UserRole {
  userId     BigInt
  roleId     BigInt
  assignedAt DateTime @default(now()) @db.Timestamptz
  assignedBy String? @db.VarChar(120)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role RbacRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId], name: "idx_user_role_role_id")
  @@map("user_role")
}
