upstream backend_upstream {
    server ${UPSTREAM_HOST}:${UPSTREAM_PORT};
}

server {
    listen 8080;
    server_name _;

    set $https_redirect_port ${HTTPS_REDIRECT_PORT};

    if ($https_redirect_port = 443) {
        return 308 https://$host$request_uri;
    }

    return 308 https://$host:$https_redirect_port$request_uri;
}

server {
    listen 8443 ssl;
    server_name _;

    ssl_certificate ${TLS_CERT_PATH};
    ssl_certificate_key ${TLS_KEY_PATH};
    ssl_client_certificate ${MTLS_CA_PATH};
    ssl_verify_client ${MTLS_VERIFY_MODE};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 10m;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        proxy_pass http://backend_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-SSL-Client-Verify $ssl_client_verify;
        proxy_set_header X-SSL-Client-DN $ssl_client_s_dn;
        proxy_set_header X-SSL-Client-Issuer $ssl_client_i_dn;
    }
}

