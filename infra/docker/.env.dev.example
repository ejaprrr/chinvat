POSTGRES_DB=chinvat
POSTGRES_USER=chinvat
POSTGRES_PASSWORD=chinvat
POSTGRES_EXPOSED_PORT=5432

# Backend app env (mirrored from backend/.env.example)
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
DB_NAME=chinvat
DB_HOST=localhost
DB_PORT=5432
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_USERNAME=postgres
DB_PASSWORD=postgres
JPA_SHOW_SQL=true
JPA_DDL_AUTO=update
H2_CONSOLE_ENABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:3000, http://172.20.10.1, https://172.20.10.1

APP_VERSION=0.0.1-SNAPSHOT
APP_TIME_ZONE=UTC
APP_DEBUG_PORT=5005
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
FNMT_PROXY_SHARED_SECRET=dev-fnmt-proxy-secret

# Short-lived eIDAS state lives in the auth Redis namespace/db (separate from permission cache)
EIDAS_STATE_REDIS_DEDICATED=true
EIDAS_STATE_REDIS_HOST=redis-auth
EIDAS_STATE_REDIS_PORT=6379
EIDAS_STATE_REDIS_DATABASE=0
EIDAS_STATE_REDIS_USERNAME=
EIDAS_STATE_REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Cl@ve 2.0 OIDC — only needed when SPRING_PROFILES_ACTIVE includes "clave"
# In dev/local the mock adapter is active; these variables are ignored.
# ---------------------------------------------------------------------------
# CLAVE_ISSUER_URI=https://clave-dninbsso-pre.redsara.es/OpenIdProvider/OidcProvider
# CLAVE_AUTHORIZATION_ENDPOINT=https://clave-dninbsso-pre.redsara.es/OpenIdProvider/OidcProvider/authorize
# CLAVE_TOKEN_ENDPOINT=https://clave-dninbsso-pre.redsara.es/OpenIdProvider/OidcProvider/token
# CLAVE_JWKS_URI=https://clave-dninbsso-pre.redsara.es/OpenIdProvider/OidcProvider/jwks
# CLAVE_CLIENT_ID=
# CLAVE_CLIENT_SECRET=
# CLAVE_REDIRECT_URI=https://localhost:8443/auth/eidas/callback

