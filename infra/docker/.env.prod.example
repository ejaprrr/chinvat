POSTGRES_DB=chinvat
POSTGRES_USER=chinvat
POSTGRES_PASSWORD=change-me

# Backend app env (mirrored from backend/.env.example)
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
DB_NAME=chinvat
DB_HOST=postgres
DB_PORT=5432
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_USERNAME=chinvat
DB_PASSWORD=change-me
JPA_SHOW_SQL=false
JPA_DDL_AUTO=validate
H2_CONSOLE_ENABLED=false
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example

APP_VERSION=0.0.1-SNAPSHOT
APP_TIME_ZONE=UTC
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
FNMT_PROXY_SHARED_SECRET=change-me-fnmt-secret

# Dedicated Redis for short-lived eIDAS state (separate from permission cache)
EIDAS_STATE_REDIS_DEDICATED=true
EIDAS_STATE_REDIS_HOST=redis-eidas
EIDAS_STATE_REDIS_PORT=6379
EIDAS_STATE_REDIS_DATABASE=0
EIDAS_STATE_REDIS_USERNAME=chinvat-eidas-state
EIDAS_STATE_REDIS_PASSWORD=change-me-strong-random

