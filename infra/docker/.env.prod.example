POSTGRES_DB=chinvat
POSTGRES_USER=chinvat
POSTGRES_PASSWORD=change-me

# Backend app env (mirrored from backend/.env.example)
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod, clave
DB_NAME=chinvat
DB_HOST=postgres
DB_PORT=5432
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_USERNAME=chinvat
DB_PASSWORD=change-me
JPA_SHOW_SQL=false
JPA_DDL_AUTO=validate
H2_CONSOLE_ENABLED=false
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example

APP_VERSION=0.0.1-SNAPSHOT
APP_TIME_ZONE=UTC
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
FNMT_PROXY_SHARED_SECRET=change-me-fnmt-secret

# Short-lived eIDAS state lives in the auth Redis namespace/db (separate from permission cache)
EIDAS_STATE_REDIS_DEDICATED=true
EIDAS_STATE_REDIS_HOST=redis-auth
EIDAS_STATE_REDIS_PORT=6379
EIDAS_STATE_REDIS_DATABASE=0
EIDAS_STATE_REDIS_USERNAME=chinvat-eidas-state
EIDAS_STATE_REDIS_PASSWORD=change-me-strong-random

# ---------------------------------------------------------------------------
# Cl@ve 2.0 OIDC — activate with: SPRING_PROFILES_ACTIVE=prod,clave
# Obtain endpoints from: https://clave-dninbsso.redsara.es/OpenIdProvider/OidcProvider/.well-known/openid-configuration
# Register your SP at: https://administracion.gob.es/pag_Home/atencionCiudadana/clave.html
# ---------------------------------------------------------------------------
CLAVE_ISSUER_URI=https://clave-dninbsso.redsara.es/OpenIdProvider/OidcProvider
CLAVE_AUTHORIZATION_ENDPOINT=https://clave-dninbsso.redsara.es/OpenIdProvider/OidcProvider/authorize
CLAVE_TOKEN_ENDPOINT=https://clave-dninbsso.redsara.es/OpenIdProvider/OidcProvider/token
CLAVE_JWKS_URI=https://clave-dninbsso.redsara.es/OpenIdProvider/OidcProvider/jwks
CLAVE_CLIENT_ID=change-me
CLAVE_CLIENT_SECRET=change-me-strong-random
CLAVE_REDIRECT_URI=https://your-frontend-domain.example/auth/eidas/callback

