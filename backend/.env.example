# .env.example — zkopíruj na .env.local nebo .env.prod a vyplň hodnoty.
# NIKDY necommituj .env.local ani .env.prod do Gitu.

# ─── Server ────────────────────────────────────────────────────────────────
SERVER_PORT=8080
APP_VERSION=0.0.1-SNAPSHOT
APP_TIME_ZONE=UTC

# ─── Spring ────────────────────────────────────────────────────────────────
# Profily: local | dev | prod
SPRING_PROFILES_ACTIVE=local

# ─── Database ──────────────────────────────────────────────────────────────
DB_NAME=chinvat
DB_HOST=localhost
DB_PORT=5432
DB_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Jen pro JPA debug (true/false)
JPA_SHOW_SQL=true
# Hibernate DDL: create-drop | update | validate | none
JPA_DDL_AUTO=update

# ─── H2 Console (jen local profil) ─────────────────────────────────────────
H2_CONSOLE_ENABLED=false

