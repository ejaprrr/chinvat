# --- Stage: Dev ---
FROM node:20-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends bash git && rm -rf /var/lib/apt/lists/*
COPY package.json package-lock.json ./
RUN npm ci --include=optional --no-audit --no-fund \
	&& ARCH="$(dpkg --print-architecture)" \
	&& case "$ARCH" in \
		arm64) TARGET_SUFFIX="linux-arm64-gnu" ;; \
		amd64) TARGET_SUFFIX="linux-x64-gnu" ;; \
		*) TARGET_SUFFIX="" ;; \
	esac \
	&& if [ -n "$TARGET_SUFFIX" ]; then \
		NATIVE_PKGS="$(node -e "const lock=require('./package-lock.json'); const pkgs=lock.packages||{}; const versions=new Map(); for (const [path,meta] of Object.entries(pkgs)) { if (path.startsWith('node_modules/')) versions.set(path.slice(13), meta.version); } const wanted=new Map(); for (const meta of Object.values(pkgs)) { const opt=meta && meta.optionalDependencies; if (!opt) continue; for (const [name,ver] of Object.entries(opt)) { if (name.includes(process.argv[1])) wanted.set(name, versions.get(name) || ver); } } process.stdout.write([...wanted.entries()].map(([name,ver]) => (name+'@'+ver)).join(' '));" "$TARGET_SUFFIX")"; \
		if [ -n "$NATIVE_PKGS" ]; then npm install --no-save --no-audit --no-fund $NATIVE_PKGS; fi; \
	fi
COPY . .
EXPOSE 3000
CMD ["npm", "run", "dev"]
